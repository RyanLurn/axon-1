{
  "name": "@repo/auth",
  "version": "0.0.1",
  "type": "module",
  "private": "true",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "lint": "eslint --cache"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    }
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:",
    "better-auth": "1.6.11",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/db": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/tsdown-config": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
