{
  "name": "@repo/fs",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "eslint --cache",
    "try": "bun run --bun src/try.ts"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    }
  },
  "dependencies": {
    "@repo/errors": "workspace:*",
    "@repo/path": "workspace:*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsdown-config": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
