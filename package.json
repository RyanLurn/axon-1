{
  "name": "axon-1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "format": "prettier . --write --cache",
    "format:check": "prettier . --check --cache",
    "check": "turbo run check-types lint && bun run format:check",
    "db:generate": "bun --elide-lines 0 --filter @repo/db generate",
    "db:migrate": "bun --elide-lines 0 --filter @repo/db migrate",
    "db:studio": "bun --elide-lines 0 --filter @repo/db studio"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "configs/*",
      "packages/*"
    ],
    "catalog": {
      "@t3-oss/env-core": "0.13.11",
      "@types/bun": "1.3.14",
      "@types/node": "25.9.1",
      "better-auth": "1.6.11",
      "eslint": "10.4.0",
      "tsdown": "0.22.0",
      "typescript": "6.0.3",
      "zod": "4.4.3"
    }
  },
  "devDependencies": {
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "2.9.14"
  },
  "packageManager": "bun@1.3.14"
}
